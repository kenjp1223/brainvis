# brain-vis

Utilities for mouse-brain visualization:

- **RGBA**: apply transparency masks to RGBA images.
- **Overlay**: colorize a 3D volume and overlay contours.
- **Regions**: work with tree-structured brain region data and create masks.
- **Sunburst app**: interactive Dash app that links a tree (e.g., atlas ontology) to brain slice images.

## Install (editable)

```bash
pip install -e /path/to/brain_vis
```

## Quick start

### RGBA transparency
```python
import numpy as np
from brain_vis.rgba import set_transparency

rgba = np.zeros((100,100,4), dtype=np.uint8); rgba[...,3]=255
mask = np.zeros((100,100), dtype=bool); mask[20:80, 20:80] = True
rgba2 = set_transparency(rgba, mask)
```

### Contour overlay
```python
import numpy as np
from brain_vis.overlay import overlap_contour
import matplotlib.pyplot as plt

vol = np.random.randn(10, 128, 128).astype(np.float32)  # data_by_img
contour = (np.random.rand(10, 128, 128) > 0.95).astype(np.float32)
base_adj, overlayed = overlap_contour(vol, contour, cmin=-2, cmax=2)

plt.imshow(overlayed[5])
plt.axis("off")
```

### Region masking

```python
import numpy as np
import pandas as pd
from brain_vis.regions import create_mask_for_region, get_subregions

# Example atlas data with tree structure
atlas_df = pd.DataFrame({
    "id": [0, 1, 2, 3, 4],
    "parent_id": [-1, 0, 0, 1, 1],
    "name": ["root", "Region A", "Region B", "Region A1", "Region A2"],
})

# Create a 2D or 3D atlas image (labels correspond to region IDs)
atlas_img = np.random.randint(0, 5, size=(128, 128), dtype=np.int32)

# Create a mask for a specific region
mask = create_mask_for_region(
    atlas_id=1,
    atlasimg=atlas_img,
    atlas_df=atlas_df,
    include_subregions=False  # Only region 1
)

# Create a mask including all subregions
mask_with_subregions = create_mask_for_region(
    atlas_id=1,
    atlasimg=atlas_img,
    atlas_df=atlas_df,
    include_subregions=True  # Includes regions 1, 3, and 4
)

# Get all subregions of a region
subregions_df = get_subregions(
    dataframe=atlas_df,
    region_id=1,
    return_original=True  # Include the original region
)

# Use custom column names
atlas_df_custom = pd.DataFrame({
    "region_id": [0, 1, 2, 3, 4],
    "parent_region_id": [-1, 0, 0, 1, 1],
})

subregions_df = get_subregions(
    dataframe=atlas_df_custom,
    region_id=1,
    id_col="region_id",
    parent_id_col="parent_region_id"
)
```

### Dash sunburst + image viewer
```python
import numpy as np, pandas as pd
from brain_vis.sunburst_app import run_app

# Fake data
Z, H, W = 20, 128, 128
data_by_img = np.random.randn(Z, H, W).astype(np.float32)
annotated_atlas_img = np.random.randint(0, 5, size=(Z,H,W), dtype=np.int32)

df = pd.DataFrame({
    "id":[0,1,2,3,4],
    "parent_id":[-1,0,0,1,1],
    "acronym":["root","A","B","A1","A2"],
    "parent_acronym":["", "root","root","A","A"],
    "name":["root","Region A","Region B","Region A1","Region A2"],
    "rejected":[False, True, False, True, False],
})

# Option 1: Use the built-in get_subregions function
from brain_vis.regions import get_subregions

def get_subregions_func(df_region, selected_id, return_original=True):
    return get_subregions(df_region, selected_id, return_original=return_original)

# Option 2: Define a custom implementation
# def get_subregions_func(df_region, selected_id, return_original=True):
#     parents = {row.id: row.parent_id for row in df_region.itertuples()}
#     children = {}
#     for cid, pid in parents.items():
#         children.setdefault(pid, []).append(cid)
#     todo, out = [selected_id], set()
#     while todo:
#         x = todo.pop()
#         if x in out: continue
#         out.add(x)
#         todo.extend(children.get(x, []))
#     return df_region[df_region["id"].isin(out)]

app = run_app(
    data_by_region=df,
    data_by_img=data_by_img,
    annotated_atlas_img=annotated_atlas_img,
    outputpath="./out",
    get_subregions_func=get_subregions_func,
    debug=True,
)
# In a script, call: app.run_server(debug=True)
```

## Notes
- For `sunburst_app`, you can pass a custom `get_subregions_func(data_by_region, id, return_original=True)->DataFrame`, or use the built-in `get_subregions` from `brain_vis.regions`.
- The `get_subregions` and `create_mask_for_region` functions support custom column names via `id_col` and `parent_id_col` parameters (defaults: `"id"` and `"parent_id"`).
- Images are shown with RGBA overlays; TIFF export uses `tifffile`.
